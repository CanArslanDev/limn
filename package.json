{
  "name": "traceworks",
  "version": "0.1.0",
  "description": "TypeScript-first library for building, debugging, and operating LLM applications. Trace your AI calls. Locally.",
  "license": "MIT",
  "author": "Can Arslan <can.arslan@nodelabs.software>",
  "homepage": "https://github.com/CanArslanDev/traceworks",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CanArslanDev/traceworks.git"
  },
  "bugs": {
    "url": "https://github.com/CanArslanDev/traceworks/issues"
  },
  "keywords": [
    "ai",
    "llm",
    "anthropic",
    "openai",
    "agent",
    "observability",
    "tracing",
    "claude",
    "gpt",
    "tool-use"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./agent": {
      "types": "./dist/agent/index.d.ts",
      "import": "./dist/agent/index.js",
      "require": "./dist/agent/index.cjs"
    },
    "./inspect": {
      "types": "./dist/inspect/index.d.ts",
      "import": "./dist/inspect/index.js",
      "require": "./dist/inspect/index.cjs"
    },
    "./errors": {
      "types": "./dist/errors/index.d.ts",
      "import": "./dist/errors/index.js",
      "require": "./dist/errors/index.cjs"
    }
  },
  "bin": {
    "traceworks": "./dist/cli/index.js"
  },
  "files": ["dist", "README.md", "CHANGELOG.md", "LICENSE"],
  "engines": {
    "node": ">=20.10.0"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "verify": "pnpm run lint && pnpm run typecheck && pnpm run typecheck:test && pnpm run test",
    "prepublishOnly": "pnpm run verify && pnpm run build",
    "release": "pnpm run verify && pnpm run build && npm publish --access public"
  },
  "dependencies": {
    "zod": "3.23.8"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.30.0",
    "openai": ">=4.60.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "openai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.30.1",
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^2.1.2",
    "openai": "^4.67.3",
    "tsup": "^8.3.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  }
}
